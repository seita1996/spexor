{
  "name": "spexor",
  "version": "0.1.0",
  "private": true,
  "description": "Manual spec tracker for Gherkin-based QA workflows.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.15.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "lefthook"
    ]
  },
  "scripts": {
    "dev": "pnpm --filter @spexor/web dev",
    "build": "pnpm --filter @spexor/web build",
    "release:version": "node ./scripts/release/version.mjs",
    "harness:check": "node ./scripts/harness/check-harness.mjs",
    "codex:turn-check": "node ./scripts/harness/codex-turn-check.mjs",
    "format": "biome format --write .",
    "lint": "oxlint .",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "guard:fast": "pnpm harness:check && pnpm lint && pnpm typecheck",
    "guard": "pnpm guard:fast && pnpm test",
    "agent:start": "node ./scripts/agent-start.mjs",
    "prepare": "lefthook install",
    "release:check": "pnpm guard && pnpm build",
    "release:publish": "pnpm -r publish --access public --no-git-checks --report-summary"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "jsdom": "^29.0.1",
    "lefthook": "^1.13.6",
    "oxlint": "^1.29.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^6.2.6",
    "vitest": "^4.1.2"
  }
}
